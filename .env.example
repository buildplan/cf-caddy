# Token is used by Caddy to perform DNS-01 challenges for Let's Encrypt/ZeroSSL.
# Generate this in your Cloudflare Dashboard -> My Profile -> API Tokens.
# Required Permissions: 
#   - Zone / Zone / Read
#   - Zone / DNS / Edit
# ------------------------------------------------------------------------------
CF_API_TOKEN=your_cloudflare_api_token_here

# (Optional) If you decide to parameterize your domain or email later, 
# you can add them here as well:
# MY_DOMAIN=mydomain.test
# ACME_EMAIL=admin@mydomain.test
